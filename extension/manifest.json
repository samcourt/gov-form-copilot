{
  "manifest_version": 3,
  "name": "Gov Form Copilot",
  "version": "0.1.0",
  "description": "Supervised assistant for completing government forms with user approval.",
  "permissions": ["activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.enrol.education.nsw.gov.au/*",
    "https://*.education.nsw.gov.au/*",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Gov Form Copilot"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.enrol.education.nsw.gov.au/*",
        "https://*.education.nsw.gov.au/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}

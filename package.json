{
  "name": "gov-form-copilot",
  "version": "0.5.1-alpha",
  "private": true,
  "type": "module",
  "workspaces": ["extension", "server", "shared", "web"],
  "scripts": {
    "install:all": "npm install",
    "dev:server": "npm --workspace=@gov-form-copilot/server run dev",
    "dev:web": "npm --workspace=@gov-form-copilot/web run dev",
    "build:shared": "npm --workspace=@gov-form-copilot/shared run build",
    "build:server": "npm --workspace=@gov-form-copilot/server run build",
    "build:extension": "npm --workspace=@gov-form-copilot/extension run build",
    "build:web": "npm --workspace=@gov-form-copilot/web run build",
    "build": "npm run build:shared && npm run build:server && npm run build:extension && npm run build:web",
    "test:server": "npm --workspace=@gov-form-copilot/server run test",
    "test": "npm run test:server",
    "verify": "npm run build && npm run test",
    "typecheck": "npm --workspaces run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
